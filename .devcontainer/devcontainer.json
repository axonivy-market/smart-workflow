{
  "name": "Axon Ivy",
  "image": "mcr.microsoft.com/devcontainers/base:trixie",
  "forwardPorts": [
    8080,
    6006,
    4317
  ],
  "onCreateCommand": "mvn clean package --batch-mode -Dmaven.test.skip=true -Divy.script.validation.skip=true -Divy.engine.directory=/usr/lib/axonivy-engine",
  "postCreateCommand": "docker ps --format '{{.Names}}' | grep -qx 'phoenix' || (docker ps -a --format '{{.Names}}' | grep -qx 'phoenix' && docker start phoenix || docker run -d --name phoenix -p 6006:6006 -p 4317:4317 arizephoenix/phoenix:nightly)",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    "ghcr.io/devcontainers/features/java:1": {
      "version": "25",
      "installMaven": "true",
      "jdkDistro": "tem"
    },
    "ghcr.io/axonivy/devcontainer-features/engine:1": {
      "downloadUrl": "https://dev.axonivy.com/permalink/dev/axonivy-engine-slim.zip",
      "engineHome": "/usr/lib/axonivy-engine"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "axonivy.vscode-designer-14",
        "vscjava.vscode-java-pack",
        "alphabotsec.vscode-eclipse-keybindings",
        "redhat.vscode-yaml",
        "mhutchie.git-graph",
        "huizhou.githd",
        "catppuccin.catppuccin-vsc-icons"
      ],
      "settings": {
        "axonivy.engine.releaseTrain": "/usr/lib/axonivy-engine",
        "java.jdt.ls.java.home": "/usr/local/sdkman/candidates/java/current/",
        "java.server.launchMode": "Standard"
      }
    }
  }
}