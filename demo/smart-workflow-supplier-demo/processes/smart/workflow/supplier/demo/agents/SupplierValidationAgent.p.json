      "type" : "ProgramInterface",
      "name" : "Supplier Duplicate Check Agent",
      "config" : {
        "javaClass" : "com.axonivy.utils.smart.workflow.AgenticProcessCall",
        "userConfig" : {
          "system" : "You are a supplier duplicate-check specialist for an ERP onboarding system. You will be given the details of a new supplier being onboarded and a pre-fetched list of similar suppliers already in the database. Analyze the results carefully and return a structured SupplierAgentResponse with: suppliers (the full list from the database results), isSupplierExisting (true if any similar suppliers were found, false otherwise), matchScore (0-100: 85+ = high confidence match, 50-84 = possible match, below 50 = low similarity; use 0 if no matches), and feedback (a concise human-readable summary of what was found and how closely they match, explicitly noting name similarity, whether the country matches, and whether the business purpose overlaps — a same-country supplier in the same business category is a stronger duplicate signal even if the name differs slightly).",
          "tools" : "[]",
          "resultType" : "com.axonivy.utils.smart.workflow.demo.supplier.agent.SupplierAgentResponse.class",
          "resultMapping" : "in.agentResponse",
          "query" : "Check for duplicate suppliers for this new supplier being onboarded:\\n\\nNEW SUPPLIER DETAILS:\\nName: <%=in.request.supplier.businessName%>\\nCountry: <%=in.request.supplier.businessAddress != null ? in.request.supplier.businessAddress.country : \"N/A\"%>\\nVAT ID: <%=in.request.supplier.vatId != null ? in.request.supplier.vatId : \"N/A\"%>\\nBusiness Purpose: <%=in.request.supplier.businessPurpose%>\\n\\nEXISTING SIMILAR SUPPLIERS FROM DATABASE:\\n<%= dev.langchain4j.internal.Json.toJson(in.toolResponse) %>"
        }
      },
