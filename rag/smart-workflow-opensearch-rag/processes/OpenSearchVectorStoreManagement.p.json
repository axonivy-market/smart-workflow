{
  "$schema" : "https://json-schema.axonivy.com/14.0-dev/project/process.json",
  "id" : "A1B2C3D4E5F60012",
  "kind" : "CALLABLE_SUB",
  "config" : {
    "data" : "OpenSearchVectorStoreManagementData"
  },
  "elements" : [ {
      "id" : "f0",
      "type" : "CallSubStart",
      "name" : "createVectorStore(String,List)",
      "config" : {
        "signature" : "createVectorStore",
        "input" : {
          "params" : [
            { "name" : "collection", "type" : "String", "desc" : "OpenSearch index name to ingest documents into." },
            { "name" : "sources", "type" : "java.util.List<String>", "desc" : "Document sources to index: plain text strings." }
          ],
          "map" : {
            "out.collection" : "param.collection",
            "out.sources" : "param.sources"
          }
        },
        "result" : {
          "params" : [
            { "name" : "result", "type" : "com.axonivy.utils.smart.workflow.rag.pipeline.RagResult", "desc" : "Ingestion result: answer contains the number of indexed segments, error contains failure details." }
          ],
          "map" : {
            "result.result" : "in.result"
          }
        }
      },
      "visual" : {
        "at" : { "x" : 384, "y" : 72 },
        "description" : "Index documents into an OpenSearch collection using semantic embeddings. Accepts plain text strings as sources."
      },
      "connect" : [
        { "id" : "f4", "to" : "f1" }
      ]
    }, {
      "id" : "f1",
      "type" : "Script",
      "name" : "Log Input",
      "config" : {
        "output" : {
          "code" : "ivy.log.info(\"createVectorStore collection='\" + in.collection + \"', sources=\" + (in.sources == null ? 0 : in.sources.size()));"
        }
      },
      "visual" : {
        "at" : { "x" : 576, "y" : 72 }
      },
      "connect" : [
        { "id" : "f5", "to" : "f2" }
      ]
    }, {
      "id" : "f2",
      "type" : "Script",
      "name" : "Ingest",
      "config" : {
        "output" : {
          "code" : [
            "import com.axonivy.utils.smart.workflow.rag.pipeline.internal.OpenSearchIngestor;",
            "import com.axonivy.utils.smart.workflow.rag.pipeline.RagResult;",
            "",
            "if (in.sources == null || in.sources.isEmpty()) {",
            "  in.result = new RagResult(\"No sources provided for ingestion.\");",
            "} else {",
            "  in.result = new OpenSearchIngestor().ingest(in.collection, in.sources);",
            "}"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 1264, "y" : 72 }
      },
      "connect" : [
        { "id" : "f6", "to" : "f3" }
      ]
    }, {
      "id" : "f3",
      "type" : "CallSubEnd",
      "visual" : {
        "at" : { "x" : 1456, "y" : 72 }
      }
    } ]
}