{
  "$schema" : "https://json-schema.axonivy.com/14.0-dev/project/process.json",
  "id" : "1A2B3C4D5E6F7A80",
  "kind" : "CALLABLE_SUB",
  "config" : {
    "data" : "Business.AxonIvyInfoChat.Agents.AxonIvyInfoChatAgentData"
  },
  "elements" : [ {
      "id" : "f3",
      "type" : "CallSubStart",
      "name" : "askAxonIvyInfo(String)",
      "config" : {
        "signature" : "askAxonIvyInfo",
        "input" : {
          "params" : [
            { "name" : "question", "type" : "String", "desc" : "" }
          ],
          "map" : {
            "out.question" : "param.question"
          }
        },
        "result" : {
          "params" : [
            { "name" : "aiResponse", "type" : "String", "desc" : "" }
          ],
          "map" : {
            "result.aiResponse" : "in.result.aiResult"
          }
        }
      },
      "visual" : {
        "at" : { "x" : 104, "y" : 208 }
      },
      "connect" : [
        { "id" : "f4", "to" : "f5" }
      ]
    }, {
      "id" : "f5",
      "type" : "ProgramInterface",
      "name" : "Web Search Agent",
      "config" : {
        "javaClass" : "com.axonivy.utils.smart.workflow.AgenticProcessCall",
        "userConfig" : {
          "system" : "You are an Axon Ivy knowledge assistant. Your job is to help users find accurate, up-to-date information about Axon Ivy products, features, and documentation.\n\nInstructions:\n1. ALWAYS use the webSearch tool to find information before answering. Do not rely on prior knowledge alone.\n2. Search with relevant keywords related to the user's question and Axon Ivy.\n3. Synthesize the search results into a clear, well-structured response.\n4. Format your response as clean HTML:\n   - Use a <p> tag for the summary paragraph\n   - Use <ul><li> for key points or bullet lists\n   - At the end, include a 'Sources' section with clickable links: <a href=\"URL\" target=\"_blank\">Title</a>\n5. If no relevant results are found, politely inform the user and suggest rephrasing their question.\n6. Keep responses concise and focused on the user's question.",
          "tools" : "[\"webSearch\"]",
          "resultType" : "Business.AxonIvyInfoChat.AxonIvyInfoChatResponse.class",
          "resultMapping" : "in.result",
          "query" : "<%=in.question%>"
        },
        "exceptionHandler" : "f8"
      },
      "visual" : {
        "at" : { "x" : 328, "y" : 208 }
      },
      "connect" : [
        { "id" : "f6", "to" : "f7" }
      ]
    }, {
      "id" : "f7",
      "type" : "CallSubEnd",
      "visual" : {
        "at" : { "x" : 552, "y" : 208 }
      }
    }, {
      "id" : "f8",
      "type" : "ErrorStartEvent",
      "name" : "ivy:error:program:exception",
      "config" : {
        "errorCode" : "ivy:error:program:exception",
        "output" : {
          "code" : [
            "ivy.log.error(exception);",
            "error.printStackTrace();"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 104, "y" : 304 }
      },
      "connect" : [
        { "id" : "f9", "to" : "f10" }
      ]
    }, {
      "id" : "f10",
      "type" : "TaskEnd",
      "visual" : {
        "at" : { "x" : 552, "y" : 304 }
      }
    } ]
}
