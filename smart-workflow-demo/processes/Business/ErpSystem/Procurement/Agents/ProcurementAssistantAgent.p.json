        "tool"
      ],
      "visual" : {
        "at" : { "x" : 96, "y" : 320 },
        "description" : "Use this tool to answer any question about procurement policies, rules, procedures, approval steps, or guidelines. Always call this tool instead of answering directly when the user asks a procurement-related question."
      },
