{
  "$schema" : "https://json-schema.axonivy.com/14.0-dev/project/process.json",
  "id" : "20A06501DF1761AB",
  "kind" : "CALLABLE_SUB",
  "config" : {
    "data" : "com.axonivy.utils.ai.ProcurementAssistantAgentData"
  },
  "elements" : [ {
      "id" : "f0",
      "type" : "CallSubStart",
      "name" : "invokeAssistantAgent",
      "config" : {
        "signature" : "invokeAssistantAgent",
        "input" : {
          "params" : [
            { "name" : "query", "type" : "String", "desc" : "The user's message or question" },
            { "name" : "chatHistory", "type" : "java.util.List<String>", "desc" : "Previous conversation messages" },
            { "name" : "request", "type" : "com.axonivy.utils.smart.workflow.demo.erp.procurement.model.ProcurementRequest", "desc" : "The current procurement request" }
          ],
          "map" : {
            "out.query" : "param.query",
            "out.chatHistory" : "param.chatHistory",
            "out.request" : "param.request"
          }
        },
        "result" : {
          "params" : [
            { "name" : "agentResponse", "type" : "com.axonivy.utils.smart.workflow.demo.erp.procurement.agent.ProcurementAgentResponse", "desc" : "Agent response containing text result and per-item feedback list" },
            { "name" : "request", "type" : "com.axonivy.utils.smart.workflow.demo.erp.procurement.model.ProcurementRequest", "desc" : "The updated procurement request (hasTrouble flags, modifications applied)" }
          ],
          "map" : {
            "result.agentResponse" : "in.agentResponse",
            "result.request" : "in.request"
          }
        }
      },
      "visual" : {
        "at" : { "x" : 96, "y" : 64 }
      },
      "connect" : [
        { "id" : "e10", "to" : "f30" }
      ]
    }, {
      "id" : "f30",
      "type" : "Script",
      "name" : "Set Today + Format Request",
      "config" : {
        "output" : {
          "code" : [
            "in.today = java.time.LocalDate.now().toString();",
            "in.userLanguage = ivy.session.contentLocale.getDisplayLanguage();",
            "if (in.chatHistory != null && !in.chatHistory.isEmpty()) {",
            "  in.formattedHistory = String.join(\"\\n\", in.chatHistory);",
            "} else {",
            "  in.formattedHistory = \"\";",
            "}",
            "",
            "if (in.request != null) {",
            "  java.lang.StringBuilder sb = new java.lang.StringBuilder();",
            "  sb.append(\"Project: \").append(in.request.getProjectName() != null ? in.request.getProjectName() : \"-\").append(\"\\n\");",
            "  sb.append(\"Cost Center: \").append(in.request.getProjectNumberCostCenter() != null ? in.request.getProjectNumberCostCenter() : \"-\").append(\"\\n\");",
            "  sb.append(\"Priority: \").append(in.request.getPriority() != null ? in.request.getPriority() : \"-\").append(\"\\n\");",
            "  sb.append(\"Requester: \").append(in.request.getRequester() != null ? in.request.getRequester() : \"-\").append(\"\\n\");",
            "  sb.append(\"Status: \").append(in.request.getStatus() != null ? in.request.getStatus() : \"-\").append(\"\\n\");",
            "  int itemCount = in.request.getMaterialItems() != null ? in.request.getMaterialItems().size() : 0;",
            "  sb.append(\"Material Items: \").append(itemCount).append(\"\\n\");",
            "  if (itemCount > 0) {",
            "    for (int i = 0; i < itemCount; i++) {",
            "      com.axonivy.utils.smart.workflow.demo.erp.procurement.model.ProcurementItem mi = in.request.getMaterialItems().get(i);",
            "      sb.append(\"  \").append(i + 1).append(\". \").append(mi.getMaterialDescription())",
            "        .append(\" – Qty: \").append(mi.getQuantity()).append(\" \").append(mi.getUnit()).append(\"\\n\");",
            "    }",
            "  }",
            "  in.formattedRequest = sb.toString();",
            "} else {",
            "  in.formattedRequest = \"No active procurement request.\";",
            "}"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 256, "y" : 64 }
      },
      "connect" : [
        { "id" : "e31", "to" : "f2" }
      ]
    }, {
      "id" : "f2",
      "type" : "ProgramInterface",
      "name" : "Procurement Assistant Agent",
      "config" : {
        "javaClass" : "com.axonivy.utils.smart.workflow.AgenticProcessCall",
        "userConfig" : {
          "system" : "Today's date: <%= in.today %>.\n<%= in.request == null ? \"\" : \"Current Procurement Request:\\n\\n\" + dev.langchain4j.internal.Json.toJson(in.request) %>\n\n## Tool Routing\n- For any question about procurement policies, procedures, rules, or guidelines: always call the answerProcurementQuestion tool.\n- To check whether the current request can be fulfilled from inventory: call the analyzeRequest tool.\n- When the user wants to resolve trouble items, find alternatives, or fix failed items: check the conversation history first. If findAlternativeItems has NOT been called yet (no alternative suggestions in the history), call findAlternativeItems. If alternatives were already presented in the history, call applyFeedbackReplacements with the current request and the feedbackList from the previous findAlternativeItems response.\n- When the user wants to add, remove, or change items or header fields in the request: call modifyRequest with the current request and a clear description of the change.\n- Never answer procurement policy questions from your own knowledge — always delegate to the appropriate tool.\n\n## After analyzeRequest Returns\n- The `feedbackList` must exactly match the tool output. Do not modify, summarize, reorder, or omit any entries.\n- No failures in feedbackList: keep `result` to max 20 words; do not repeat or summarize feedbackList content.\n- One or more failures in feedbackList: set `result` to ask the user whether they want help finding alternatives.\n\n## After findAlternativeItems Returns (all calls complete)\n- The `feedbackList` must exactly match the tool output. Do not modify, summarize, reorder, or omit any entries. Especially field `rankingAnalysis`\n- Set `result` to briefly present the alternatives and ask the user if they want to apply them (max 30 words), e.g. \"Here are alternative suggestions for the trouble items. Would you like to apply these replacements?\"\n\n## After applyFeedbackReplacements Returns\n- Keep `result` short (max 20 words), e.g. \"Replacements have been applied to your request.\"",
          "tools" : "[\"answerProcurementQuestion\", \"analyzeRequest\", \"findAlternativeItems\", \"applyFeedbackReplacements\"]",
          "resultType" : "com.axonivy.utils.smart.workflow.demo.erp.procurement.agent.ProcurementAgentResponse.class",
          "resultMapping" : "in.agentResponse",
          "query" : "Conversation history:\r\n<%= in.formattedHistory %>\r\n\r\n---\r\n\r\nNew user message:\r\n<%= in.query %>"
        }
      },
      "visual" : {
        "at" : { "x" : 488, "y" : 64 },
        "size" : { "width" : 192, "height" : 62 }
      },
      "connect" : [
        { "id" : "f75", "to" : "f77" }
      ]
    }, {
      "id" : "f1",
      "type" : "CallSubEnd",
