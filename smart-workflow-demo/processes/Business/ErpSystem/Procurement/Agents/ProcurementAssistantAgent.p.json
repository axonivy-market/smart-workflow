            { "name" : "response", "type" : "com.axonivy.utils.smart.workflow.demo.erp.procurement.agent.ProcurementAgentResponse", "desc" : "Response with the answer text" }
          ],
          "map" : {
            "result.response" : "in.agentResponse"
          }
        }
      },
