      }
    }, {
      "id" : "f70",
      "type" : "CallSubStart",
      "name" : "findAlternativeItems(ProcurementRequest)",
      "config" : {
        "signature" : "findAlternativeItems",
        "input" : {
          "params" : [
            { "name" : "request", "type" : "com.axonivy.utils.smart.workflow.demo.erp.procurement.model.ProcurementRequest", "desc" : "The current procurement request containing trouble items to find alternatives for" }
          ],
          "map" : {
            "out.request" : "param.request"
          }
        },
        "result" : {
          "params" : [
            { "name" : "agentResponse", "type" : "com.axonivy.utils.smart.workflow.demo.erp.procurement.agent.ProcurementAgentResponse", "desc" : "Agent response with feedback list of alternatives for each trouble item" }
          ],
          "map" : {
            "result.agentResponse" : "in.agentResponse"
          }
        }
      },
      "tags" : [
        "tool"
      ],
      "visual" : {
        "at" : { "x" : 88, "y" : 824 },
        "description" : "Finds alternative inventory items for all trouble items in the request. Call this when the user wants to find alternatives or resolve items flagged with hasTrouble."
      },
      "connect" : [
        { "id" : "b70", "to" : "f82" }
      ]
    }, {
      "id" : "f82",
      "type" : "Script",
      "name" : "Init alternative loop",
      "config" : {
        "output" : {
          "code" : [
            "in.count = 0;",
            "in.agentFeedbackList = new java.util.ArrayList();",
            "in.troubleItems = new java.util.ArrayList();",
            "for (com.axonivy.utils.smart.workflow.demo.erp.procurement.model.ProcurementItem mi : in.request.getMaterialItems()) {",
            "    if (mi.isHasTrouble()) {",
            "        in.troubleItems.add(mi);",
            "    }",
            "}"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 264, "y" : 824 }
      },
      "connect" : [
        { "id" : "b71", "to" : "f83" }
      ]
    }, {
      "id" : "f83",
      "type" : "Alternative",
      "name" : "Has next trouble item?",
      "config" : {
        "conditions" : {
          "b72" : "in.count < in.troubleItems.size()"
        }
      },
      "visual" : {
        "at" : { "x" : 440, "y" : 824 },
        "labelOffset" : { "x" : 64, "y" : 24 }
      },
      "connect" : [
        { "id" : "b72", "to" : "f84" },
        { "id" : "b73", "to" : "f85", "label" : {
            "name" : "Done",
            "segment" : 0.26,
            "offset" : { "x" : 49, "y" : -64 }
          } }
      ]
    }, {
      "id" : "f84",
      "type" : "Script",
      "name" : "Load trouble item and inventory",
      "config" : {
        "output" : {
          "code" : [
            "in.materialItem = in.troubleItems.get(in.count);",
            "in.inventoryItems = com.axonivy.utils.smart.workflow.demo.erp.procurement.repository.InventoryRepository.getInstance()",
            "    .findSimilarItems(in.materialItem);"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 624, "y" : 824 },
        "size" : { "width" : 160, "height" : 62 }
      },
      "connect" : [
        { "id" : "b74", "to" : "f86" }
      ]
    }, {
      "id" : "f86",
      "type" : "ProgramInterface",
      "name" : "Analyze & Rank Alternatives",
      "config" : {
        "javaClass" : "com.axonivy.utils.smart.workflow.AgenticProcessCall",
        "userConfig" : {
          "system" : "You are a procurement analyst.\r\nEvaluate all available inventory alternatives for a requested material item and produce a structured ranked analysis.\r\n\r\n## Evaluation Criteria — score each candidate 1–5 on:\r\n1. Specification match — material type, grade, class, technical specs\r\n2. Quantity availability — can inventory stock cover the requested quantity?\r\n3. Unit compatibility — same unit or cleanly convertible\r\n4. Price reasonableness — unit price vs requested item (lower/comparable is better)\r\n\r\n## Reasoning Process\r\n- For each candidate, reason step-by-step through each criterion before assigning a score.\r\n- Compute a total score (max 20) and rank all candidates from best to worst.\r\n- If no alternatives are available, state that clearly.\r\n\r\n## Output Format\r\nReturn ONLY the ranked list in this exact format:\r\n\r\nRANK 1: [Item Name] (ID: <id>) — Total: <X>/20\r\n  Spec: <score>/5 — <reason>\r\n  Qty: <score>/5 — <reason>\r\n  Unit: <score>/5 — <reason>\r\n  Price: <score>/5 — <reason>\r\n  Verdict: <why this is the best substitute>\r\n\r\nRANK 2: ...\r\n(continue for all candidates)",
          "tools" : "[]",
          "resultMapping" : "in.rankedAnalysis",
          "query" : "Requested item:\r\n<%= dev.langchain4j.internal.Json.toJson(in.materialItem) %>\r\n\r\nAvailable alternatives in inventory:\r\n<%= dev.langchain4j.internal.Json.toJson(in.inventoryItems) %>"
        }
      },
      "visual" : {
        "at" : { "x" : 832, "y" : 824 },
        "size" : { "width" : 192, "height" : 62 }
      },
      "connect" : [
        { "id" : "b77", "to" : "f80" }
      ]
    }, {
      "id" : "f80",
      "type" : "ProgramInterface",
