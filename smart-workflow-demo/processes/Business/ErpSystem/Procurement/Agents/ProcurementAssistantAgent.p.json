        }
      },
      "visual" : {
        "at" : { "x" : 408, "y" : 520 },
        "labelOffset" : { "x" : 64, "y" : 24 }
      },
      "connect" : [
        { "id" : "a12", "to" : "f59" },
        { "id" : "a13", "to" : "f69", "label" : {
            "name" : "Done",
            "segment" : 0.26,
            "offset" : { "x" : 49, "y" : -64 }
          } }
      ]
    }, {
      "id" : "f59",
      "type" : "Script",
      "name" : "Load corresponding inventory item",
      "config" : {
        "output" : {
          "code" : [
            "in.materialItem = in.request.getMaterialItems().get(in.count);",
            "",
            "// Step 1: find the catalog entry by material description to get its typeId",
            "List<com.axonivy.utils.smart.workflow.demo.erp.procurement.model.ProcurementItem> catalogMatches =",
            "    com.axonivy.utils.smart.workflow.demo.erp.procurement.repository.ProcurementItemRepository.getInstance()",
            "        .searchByDescription(in.materialItem.getMaterialDescription());",
            "",
            "// Step 2: look up inventory by typeId",
            "if (!catalogMatches.isEmpty()) {",
            "    String typeId = catalogMatches.get(0).getMaterialTypeId();",
            "    in.materialItem.setMaterialTypeId(typeId);",
            "    in.inventoryItem = com.axonivy.utils.smart.workflow.demo.erp.procurement.repository.InventoryRepository.getInstance()",
            "        .findByMaterialTypeId(typeId);",
            "} else {",
            "    in.inventoryItem = null;",
            "}"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 568, "y" : 520 },
        "size" : { "width" : 160, "height" : 62 }
      },
      "connect" : [
        { "id" : "a14", "to" : "f67" }
      ]
    }, {
      "id" : "f67",
      "type" : "Alternative",
      "name" : "Has inventory?",
      "config" : {
        "conditions" : {
          "a15" : "in.inventoryItem != null"
        }
      },
      "visual" : {
        "at" : { "x" : 728, "y" : 520 },
        "labelOffset" : { "y" : -24 }
      },
      "connect" : [
        { "id" : "a15", "to" : "f61" },
        { "id" : "a16", "to" : "f68", "label" : {
            "name" : "Not found"
          } }
      ]
    }, {
      "id" : "f61",
      "type" : "ProgramInterface",
      "name" : [
        "Evaluate item of the request",
        "against the inventory item"
      ],
      "config" : {
        "javaClass" : "com.axonivy.utils.smart.workflow.AgenticProcessCall",
        "userConfig" : {
          "system" : "You are a procurement analyst.\r\nGiven a requested material item and its current inventory status, evaluate whether the request can be fulfilled from stock. Provide a concise feedback covering: availability status, quantity comparison, and any risks or recommendations.\r\nDo not populate feedbackOption — it is reserved for OPTION type only.",
          "tools" : "[]",
          "resultType" : "com.axonivy.utils.smart.workflow.demo.erp.procurement.agent.feedback.AgentFeedback.class",
          "resultMapping" : "in.agentFeedback",
          "query" : "Requested Item:\r\n<%= dev.langchain4j.internal.Json.toJson(in.materialItem) %>\r\n\r\nItem in inventory:\r\n<%= dev.langchain4j.internal.Json.toJson(in.inventoryItem) %>"
        }
      },
      "visual" : {
        "at" : { "x" : 904, "y" : 520 },
        "size" : { "width" : 192, "height" : 62 }
      },
      "connect" : [
        { "id" : "a17", "to" : "f63" }
      ]
    }, {
      "id" : "f63",
      "type" : "Script",
      "name" : "Collect feedback and increment",
      "config" : {
        "output" : {
          "code" : [
            "in.agentFeedback.setId(in.materialItem.getId());",
            "in.agentFeedbackList.add(in.agentFeedback);",
            "in.materialItem.setHasTrouble(!in.agentFeedback.isSuccess());",
            "in.count = in.count + 1;"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 1120, "y" : 520 },
        "size" : { "width" : 136, "height" : 62 }
      },
      "connect" : [
        { "id" : "a19", "to" : "f57", "via" : [ { "x" : 1232, "y" : 520 }, { "x" : 1232, "y" : 760 }, { "x" : 408, "y" : 760 } ] }
      ]
    }, {
      "id" : "f68",
      "type" : "Script",
      "name" : "Set not found feedback",
      "config" : {
        "output" : {
          "code" : [
            "import com.axonivy.utils.smart.workflow.demo.erp.procurement.agent.feedback.AgentFeedback;",
            "AgentFeedback fb = new AgentFeedback();",
            "fb.setId(in.materialItem.getId());",
            "fb.setSuccess(false);",
            "fb.setMessage(\"Material '\" + in.materialItem.getMaterialDescription() + \"' does not exist in inventory.\");",
            "in.agentFeedback = fb;"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 728, "y" : 648 }
      },
      "connect" : [
        { "id" : "a18", "to" : "f63", "via" : [ { "x" : 1120, "y" : 648 } ] }
      ]
    }, {
      "id" : "f69",
      "type" : "Script",
      "name" : "Build Summary",
      "config" : {
        "output" : {
          "code" : [
            "java.lang.StringBuilder sb = new java.lang.StringBuilder();",
            "for (com.axonivy.utils.smart.workflow.demo.erp.procurement.agent.feedback.AgentFeedback fb : in.agentFeedbackList) {",
            "  sb.append(fb.isSuccess() ? \"[OK] \" : \"[!] \").append(fb.getMessage()).append(\"\\n\");",
            "}",
            "import com.axonivy.utils.smart.workflow.demo.erp.procurement.agent.ProcurementAgentResponse;",
            "ProcurementAgentResponse resp = new ProcurementAgentResponse();",
            "resp.setResult(sb.toString());",
            "resp.setFeedbackList(in.agentFeedbackList);",
            "in.agentResponse = resp;"
          ]
        }
      },
      "visual" : {
