            "if (in.agentFeedback.getFeedbackOption() == null) {",
            "    in.agentFeedback.setFeedbackOption(new FeedbackOption());",
            "}",
            "in.agentFeedback.setRankingAnalysis(in.rankedAnalysis);",
            "if (in.rankedAnalysis != null && !in.rankedAnalysis.isBlank()) {",
            "    if (in.agentFeedback.getFeedbackOption() == null) {",
            "        in.agentFeedback.setFeedbackOption(new com.axonivy.utils.smart.workflow.demo.erp.procurement.agent.feedback.FeedbackOption());",
            "    }",
            "    in.agentFeedback.getFeedbackOption().setDescription(in.rankedAnalysis);",
