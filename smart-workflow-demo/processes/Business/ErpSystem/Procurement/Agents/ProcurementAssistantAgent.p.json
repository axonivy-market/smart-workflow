            "import com.axonivy.utils.smart.workflow.demo.erp.procurement.agent.ProcurementAgentResponse;",
            "ProcurementAgentResponse resp = new ProcurementAgentResponse();",
            "resp.setResult(in.toolAnswer);",
            "in.agentResponse = resp;"
          ]
        }
      },
      "visual" : {
