      "id" : "f102",
      "type" : "Script",
      "name" : "Apply Translation",
      "config" : {
        "output" : {
          "code" : [
            "if (in.translatedResult != null && !in.translatedResult.isBlank() && in.agentResponse != null) {",
            "    java.util.List<String> parts = new java.util.ArrayList();",
            "    String remaining = in.translatedResult;",
            "    int idx;",
            "    while ((idx = remaining.indexOf(\"---SEG---\")) >= 0) {",
            "        parts.add(remaining.substring(0, idx).trim());",
            "        remaining = remaining.substring(idx + 9);",
            "    }",
            "    parts.add(remaining.trim());",
            "    if (!parts.isEmpty()) {",
            "        in.agentResponse.setResult(parts.get(0));",
            "    }",
            "    java.util.List<com.axonivy.utils.smart.workflow.demo.erp.procurement.agent.feedback.AgentFeedback> feedbackList = in.agentResponse.getFeedbackList();",
            "    if (feedbackList != null) {",
            "        for (int i = 0; i < feedbackList.size(); i++) {",
            "            int partIdx = i + 1;",
            "            if (partIdx < parts.size()) {",
            "                feedbackList.get(i).setMessage(parts.get(partIdx));",
            "            }",
            "        }",
            "    }",
            "}"
          ]
        }
