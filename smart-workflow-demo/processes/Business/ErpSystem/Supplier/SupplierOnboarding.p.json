        "at" : { "x" : 1160, "y" : 352 }
      }
    }, {
      "id" : "f209",
      "type" : "Script",
      "name" : "Init request",
      "config" : {
        "output" : {
          "code" : [
            "import com.axonivy.utils.smart.workflow.demo.erp.supplier.onboarding.OnboardingRequest;",
            "import com.axonivy.utils.smart.workflow.demo.erp.supplier.onboarding.OnboardingStatus;",
            "import com.axonivy.utils.smart.workflow.demo.erp.supplier.model.Supplier;",
            "",
            "if (in.request == null) { in.request = new OnboardingRequest(); }",
            "if (in.request.getSupplier() == null) { in.request.setSupplier(new Supplier()); }",
            "in.sessionUsername = ivy.session.getSessionUser().fullName;",
            "in.request.setCaseUuid(ivy.case.uuid().toString());",
            "if (in.request.getStatus() == null) { in.request.setStatus(OnboardingStatus.REQUEST); }"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 280, "y" : 208 }
      },
      "connect" : [
        { "id" : "f200", "to" : "f210" }
      ]
    }, {
      "id" : "f210",
      "type" : "Script",
      "name" : "Generate mock data",
      "config" : {
        "output" : {
          "code" : [
            "import com.axonivy.utils.smart.workflow.demo.erp.mock.MockDataGenerator;",
            "",
            "MockDataGenerator.ensureDepartments();"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 368, "y" : 208 }
      },
      "connect" : [
        { "id" : "f211", "to" : "f4" }
      ]
    }, {
      "id" : "f4",
      "type" : "DialogCall",
      "name" : "Supplier request form",
      "config" : {
        "dialog" : "com.axonivy.utils.smart.workflow.demo.erp.supplier.onboarding.SupplierRequestForm:start(com.axonivy.utils.smart.workflow.demo.erp.supplier.onboarding.OnboardingRequest)",
        "call" : {
          "map" : {
            "param.request" : "in.request"
          }
        },
        "output" : {
          "map" : {
            "out" : "in",
            "out.request" : "result.request"
          }
        }
      },
      "visual" : {
        "at" : { "x" : 560, "y" : 208 }
      },
      "connect" : [
        { "id" : "f102", "to" : "f150" }
      ]
    }, {
