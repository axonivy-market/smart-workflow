      "type" : "RequestStart",
      "name" : "supplierOnboarding",
      "config" : {
        "signature" : "supplierOnboarding",
        "request" : {
          "name" : "Supplier Onboarding",
          "description" : "Request a new supplier onboarding process"
        }
      },
      "visual" : {
        "at" : { "x" : 96, "y" : 208 }
      },
      "connect" : [
        { "id" : "f100", "to" : "f209" }
      ]
    }, {
      "id" : "f1",
      "type" : "TaskEnd",
      "visual" : {
        "at" : { "x" : 1160, "y" : 208 }
      }
    }, {
      "id" : "f155",
