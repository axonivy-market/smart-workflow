      "type" : "Alternative",
      "name" : "Check status",
      "config" : {
        "conditions" : {
          "f152" : "com.axonivy.utils.smart.workflow.demo.erp.supplier.onboarding.OnboardingStatus.REQUEST.equals(in.request.status)",
          "f156" : "in.request.status == null"
        }
      },
      "visual" : {
