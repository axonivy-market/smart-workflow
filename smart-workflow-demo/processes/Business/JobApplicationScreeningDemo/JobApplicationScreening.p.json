{
  "$schema" : "https://json-schema.axonivy.com/14.0-dev/project/process.json",
  "id" : "19F0A1B2C3D4E012",
  "config" : {
    "data" : "Business.JobApplicationScreeningDemo.JobApplicationScreeningData"
  },
  "elements" : [ {
      "id" : "f0",
      "type" : "RequestStart",
      "name" : "jobApplicationScreening",
      "config" : {
        "signature" : "jobApplicationScreening",
        "request" : {
          "name" : "Job Application Screening"
        }
      },
      "visual" : {
        "at" : { "x" : 96, "y" : 64 }
      },
      "connect" : [
        { "id" : "f1", "to" : "f2" }
      ]
    }, {
      "id" : "f2",
      "type" : "DialogCall",
      "name" : "Enter CV and Job Description",
      "config" : {
        "dialog" : "com.axonivy.utils.smart.workflow.demo.jobapplicationscreeningdemo.CVInput:start()",
        "output" : {
          "map" : {
            "out.cvText" : "result.cvText",
            "out.jobDescription" : "result.jobDescription"
          }
        }
      },
      "visual" : {
        "at" : { "x" : 224, "y" : 64 }
      },
      "connect" : [
        { "id" : "f3", "to" : "f4" }
      ]
    }, {
      "id" : "f4",
      "type" : "TaskSwitchEvent",
      "name" : "Step 1: Extract Candidate Profile",
      "config" : {
        "task" : {
          "name" : "Step 1: Extract Candidate Profile",
          "skipTasklist" : true
        },
        "case" : {
          "name" : "Job Application Screening"
        }
      },
      "visual" : {
        "at" : { "x" : 384, "y" : 64 }
      },
      "connect" : [
        { "id" : "f5", "to" : "f6", "color" : "default" }
      ]
    }, {
      "id" : "f6",
      "type" : "ProgramInterface",
      "name" : "Extract Candidate Profile",
      "config" : {
        "javaClass" : "com.axonivy.utils.smart.workflow.AgenticProcessCall",
        "userConfig" : {
          "system" : "You are an expert HR recruiter and talent analyst. Extract a comprehensive candidate profile from the provided CV text. Identify the candidate's full name, email, comma-separated skills, total years of relevant experience, highest education level, and a brief experience summary.",
          "resultType" : "com.axonivy.utils.smart.workflow.demo.model.CandidateProfile.class",
          "tools" : "[]",
          "resultMapping" : "in.profile",
          "query" : "Extract the candidate profile from this CV:\n\n<CV>\n<%=in.cvText != null ? in.cvText : \"\"%>\n</CV>\n\nJob description for context:\n<JOB>\n<%=in.jobDescription != null ? in.jobDescription : \"\"%>\n</JOB>"
        }
      },
      "visual" : {
        "at" : { "x" : 560, "y" : 64 },
        "size" : { "width" : 160, "height" : 62 }
      },
      "boundaries" : [ {
          "id" : "f22",
          "type" : "ErrorBoundaryEvent",
          "name" : "Extraction error",
          "config" : {
            "errorCode" : "ivy:error:program:exception",
            "output" : {
              "map" : {
                "out" : "in",
                "out.error" : "error"
              }
            }
          },
          "visual" : {
            "at" : { "x" : 616, "y" : 105 },
            "labelOffset" : { "x" : -50, "y" : 25 }
          },
          "connect" : [
            { "id" : "f21", "to" : "f20" }
          ]
        } ],
      "connect" : [
        { "id" : "f7", "to" : "f8", "color" : "default" }
      ]
    }, {
      "id" : "f8",
      "type" : "TaskSwitchEvent",
      "name" : "Step 2: Score Job Fit",
      "config" : {
        "task" : {
          "name" : "Step 2: Score Job Fit",
          "skipTasklist" : true
        }
      },
      "visual" : {
        "at" : { "x" : 752, "y" : 64 }
      },
      "connect" : [
        { "id" : "f9", "to" : "f10", "color" : "default" }
      ]
    }, {
      "id" : "f10",
      "type" : "ProgramInterface",
      "name" : "Score Job Fit",
      "config" : {
        "javaClass" : "com.axonivy.utils.smart.workflow.AgenticProcessCall",
        "userConfig" : {
          "system" : "You are an expert HR assessor. Given a candidate's profile and a job description, provide an honest fit score from 0 to 100, a boolean indicating whether the candidate is qualified, their key strengths relevant to the position, any gaps or missing qualifications, and a one-line hiring recommendation.",
          "resultType" : "com.axonivy.utils.smart.workflow.demo.model.FitScore.class",
          "tools" : "[]",
          "resultMapping" : "in.fitScore",
          "query" : "Score this candidate's fit for the position.\n\nCandidate: <%=in.profile.fullName != null ? in.profile.fullName : \"\"%>\nSkills: <%=in.profile.skills != null ? in.profile.skills : \"\"%>\nExperience: <%=in.profile.yearsOfExperience%> years\nSummary: <%=in.profile.experienceSummary != null ? in.profile.experienceSummary : \"\"%>\n\nJob Description:\n<JOB>\n<%=in.jobDescription != null ? in.jobDescription : \"\"%>\n</JOB>"
        }
      },
      "visual" : {
        "at" : { "x" : 912, "y" : 64 },
        "size" : { "width" : 160, "height" : 62 }
      },
      "connect" : [
        { "id" : "f11", "to" : "f12", "color" : "default" }
      ]
    }, {
      "id" : "f12",
      "type" : "Script",
      "name" : "Draft Communication",
      "config" : {
        "output" : {
          "code" : [
            "if (in.fitScore.qualified) {",
            "  in.communicationDraft = \"Dear \" + in.profile.fullName + \",\\n\\n\"",
            "    + \"Thank you for applying. We are pleased to invite you to an interview.\\n\\n\"",
            "    + \"Strengths noted: \" + in.fitScore.strengths + \"\\n\\n\"",
            "    + \"Best regards,\\nHR Team\";",
            "} else {",
            "  in.communicationDraft = \"Dear \" + in.profile.fullName + \",\\n\\n\"",
            "    + \"Thank you for your application. After careful review, we regret to inform you \"",
            "    + \"that we will not be moving forward at this time.\\n\\n\"",
            "    + in.fitScore.recommendation + \"\\n\\n\"",
            "    + \"Best regards,\\nHR Team\";",
            "}"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 1104, "y" : 64 }
      },
      "connect" : [
        { "id" : "f13", "to" : "f14", "color" : "default" }
      ]
    }, {
      "id" : "f14",
      "type" : "DialogCall",
      "name" : "Review Communication",
      "config" : {
        "dialog" : "com.axonivy.utils.smart.workflow.demo.jobapplicationscreeningdemo.ReviewCommunication:start(com.axonivy.utils.smart.workflow.demo.model.CandidateProfile,com.axonivy.utils.smart.workflow.demo.model.FitScore,String)",
        "call" : {
          "map" : {
            "param.profile" : "in.profile",
            "param.fitScore" : "in.fitScore",
            "param.communicationDraft" : "in.communicationDraft"
          }
        },
        "output" : {
          "map" : {
            "out.communicationDraft" : "result.communicationDraft"
          }
        }
      },
      "visual" : {
        "at" : { "x" : 1264, "y" : 64 }
      },
      "connect" : [
        { "id" : "f15", "to" : "f16" }
      ]
    }, {
      "id" : "f16",
      "type" : "Script",
      "name" : "Log screening result",
      "config" : {
        "output" : {
          "code" : [
            "ivy.log.info(\"[JobScreening] Candidate: {0} | Score: {1} | Qualified: {2}\",",
            "  in.profile.fullName, in.fitScore.score, in.fitScore.qualified);"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 1424, "y" : 64 }
      },
      "connect" : [
        { "id" : "f17", "to" : "f18", "color" : "default" }
      ]
    }, {
      "id" : "f18",
      "type" : "TaskEnd",
      "visual" : {
        "at" : { "x" : 1552, "y" : 64 }
      }
    }, {
      "id" : "f20",
      "type" : "Script",
      "name" : "Log screening error",
      "config" : {
        "output" : {
          "code" : "ivy.log.error(\"[JobScreening] AI step failed: {0}\", in.error.getMessage());"
        }
      },
      "visual" : {
        "at" : { "x" : 560, "y" : 256 }
      },
      "connect" : [
        { "id" : "f23", "to" : "f18", "via" : [ { "x" : 1552, "y" : 264 } ], "color" : "default" }
      ]
    }, {
      "id" : "f24",
      "type" : "ProcessAnnotation",
      "name" : "Multi-task AI pipeline: (1) extract candidate profile from CV, (2) score job fit, (3) draft communication. Each AI step runs as a separate Ivy task, demonstrating observable multi-step agentic processing.",
      "visual" : {
        "at" : { "x" : 448, "y" : 392 },
        "size" : { "width" : 880, "height" : 80 }
      }
    } ]
}