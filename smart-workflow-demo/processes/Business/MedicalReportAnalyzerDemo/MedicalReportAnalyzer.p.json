  "elements" : [ {
      "id" : "f0",
      "type" : "CallSubStart",
      "name" : "analyze(String)",
      "config" : {
        "signature" : "analyze",
        "input" : {
          "params" : [
            { "name" : "reportContent", "type" : "String", "desc" : "The medical report text to analyze" }
