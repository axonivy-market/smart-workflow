        "userConfig" : {
          "system" : "Extract all vital signs from this medical report. Include: blood pressure (systolic/diastolic mmHg), heart rate (bpm), respiratory rate (breaths/min), body temperature (°C/°F), BMI, and oxygen saturation (SpO2 %). Present each finding as a labelled value on its own line.",
          "tools" : "[]",
          "resultMapping" : "in.analysisResult",
          "query" : "<%=in.reportContent%>"
        }
