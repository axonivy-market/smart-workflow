        "userConfig" : {
          "system" : "You are a medical report analyzer agent. Use all available tools to comprehensively analyze the provided medical report:\n1) Use extractVitals to extract all vital signs (blood pressure, heart rate, BMI, oxygen saturation).\n2) Use identifyAbnormalities to detect out-of-range values and urgent clinical flags.\n3) Use generateSummary to produce a concise clinical summary for physician review.\nAlways call all three tools and compile their results into a cohesive analysis report.",
          "tools" : "[\"extractVitals\",\"identifyAbnormalities\",\"generateSummary\"]",
          "resultMapping" : "in.analysisResult",
          "query" : "<%=in.reportContent%>"
        },
        "exceptionHandler" : "f5"
      },
      "visual" : {
        "at" : { "x" : 288, "y" : 128 }
      },
      "connect" : [
        { "id" : "f3", "to" : "f4" }
      ]
    }, {
      "id" : "f4",
      "type" : "CallSubEnd",
