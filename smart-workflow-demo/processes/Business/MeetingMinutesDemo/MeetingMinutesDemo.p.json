            "import com.axonivy.utils.smart.workflow.demo.model.FeedbackList;",
            "",
            "FeedbackItem item = new FeedbackItem();",
            "item.setTitle(in.transcriptText);",
            "item.setDescription(in.description);",
            "item.setAssignee(in.targetLanguage);",
            "FeedbackList list = new FeedbackList();",
            "list.setItems(new java.util.ArrayList<FeedbackItem>());",
            "list.getItems().add(item);",
            "in.feedbackList = list;"
