{
  "$schema" : "https://json-schema.axonivy.com/14.0-dev/project/process.json",
  "id" : "A1B2C3D4E5F60003",
  "config" : {
    "data" : "Features.RagDemoData"
  },
  "elements" : [ {
      "id" : "f0",
      "type" : "RequestStart",
      "name" : "ragFromCms",
      "config" : {
        "signature" : "ragFromCms",
        "request" : {
          "name" : "RAG Demo: Batch Fraud Evaluation (Agent loop)"
        }
      },
      "visual" : {
        "at" : { "x" : 96, "y" : 64 }
      },
      "connect" : [
        { "id" : "f10", "to" : "f17" }
      ]
    }, {
      "id" : "f17",
      "type" : "Script",
      "name" : "Init transactions",
      "config" : {
        "output" : {
          "code" : [
            "import java.util.ArrayList;",
            "",
            "in.currentIndex = 0;",
            "in.results = new ArrayList();",
            "in.transactions = new ArrayList();",
            "",
            "in.transactions.add(\"Transaction 1: Outgoing international wire transfer of $75,000 USD to an overseas account. Beneficiary was added 4 minutes ago. Customer MFA is NOT enabled. Account accessed from a new country 45 minutes before this request. No dual approval obtained.\");",
            "",
            "in.transactions.add(\"Transaction 2: Domestic transfer of $3,000 USD to a known beneficiary on file for 2 years. Customer MFA is enabled. Login from usual home IP address. Single approval sufficient per policy.\");",
            "",
            "in.transactions.add(\"Transaction 3: International wire transfer of $250,000 USD. Only single approval obtained (no triple approval). 5 consecutive failed login attempts in the last hour. Customer KYC was last refreshed 18 months ago.\");"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 232, "y" : 64 }
      },
      "connect" : [
        { "id" : "f21", "to" : "f18" }
      ]
    }, {
      "id" : "f18",
      "type" : "Alternative",
      "name" : "More transactions?",
      "config" : {
        "conditions" : {
          "f22" : "in.currentIndex < in.transactions.size()"
        }
      },
      "visual" : {
        "at" : { "x" : 432, "y" : 64 }
      },
      "connect" : [
        { "id" : "f22", "to" : "f19", "label" : {
            "name" : "yes"
          } },
        { "id" : "f23", "to" : "f3", "label" : {
            "name" : "no",
            "segment" : 0.54
          } }
      ]
    }, {
      "id" : "f19",
      "type" : "ProgramInterface",
      "name" : "Evaluate transaction",
      "config" : {
        "javaClass" : "com.axonivy.utils.smart.workflow.AgenticProcessCall",
        "userConfig" : {
          "system" : "<%=ivy.cms.co(\"/Features/RagDemo/SystemPrompt\")%>",
          "tools" : "[\"searchDocuments\"]",
          "resultType" : "com.axonivy.utils.smart.workflow.rag.entity.RagResult.class",
          "resultMapping" : "in.ragResult",
          "query" : "\"Evaluate this transaction for fraud risk and recommend BLOCK or APPROVE.\\n\\n\" + in.transactions.get(in.currentIndex) + \"\\n\\nSearch the fraud detection policy for all applicable rules. Sources: [\\\"cms:/Features/RagDemo/FraudDetectionPolicy\\\"]\""
        }
      },
      "visual" : {
        "at" : { "x" : 640, "y" : 64 },
        "size" : { "width" : 160, "height" : 62 }
      },
      "connect" : [
        { "id" : "f24", "to" : "f20" }
      ]
    }, {
      "id" : "f20",
      "type" : "Script",
      "name" : "Collect result",
      "config" : {
        "output" : {
          "code" : [
            "import com.axonivy.utils.smart.workflow.rag.entity.RagMatch;",
            "import com.axonivy.utils.smart.workflow.rag.entity.RagResult;",
            "",
            "RagResult ragResult = in.ragResult;",
            "in.results.add(ragResult);",
            "",
            "ivy.log.info(\"--- Transaction {0} ---\", in.currentIndex + 1);",
            "ivy.log.info(\"Answer: {0}\", ragResult.getAnswer());",
            "if (ragResult.getMatches() != null) {",
            "  int i = 1;",
            "  for (RagMatch match : ragResult.getMatches()) {",
            "    ivy.log.info(\"  Match {0} (score={1}): {2}\", i++, match.getScore(), match.getContent());",
            "  }",
            "}",
            "",
            "in.currentIndex = in.currentIndex + 1;"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 848, "y" : 64 }
      },
      "connect" : [
        { "id" : "f25", "to" : "f18", "via" : [ { "x" : 848, "y" : -16 }, { "x" : 432, "y" : -16 } ] }
      ]
    }, {
      "id" : "f3",
      "type" : "TaskEnd",
      "visual" : {
        "at" : { "x" : 432, "y" : 208 }
      }
    }, {
      "id" : "f4",
      "type" : "RequestStart",
      "name" : "ragFromMixedSources",
      "config" : {
        "signature" : "ragFromMixedSources",
        "request" : {
          "name" : "RAG Demo: Fraud Alert Analysis from CMS + String"
        }
      },
      "visual" : {
        "at" : { "x" : 96, "y" : 352 }
      },
      "connect" : [
        { "id" : "f13", "to" : "f5" }
      ]
    }, {
      "id" : "f5",
      "type" : "Script",
      "name" : "Initialize fraud alert",
      "config" : {
        "output" : {
          "code" : "in.recentFraudAlert = \"ALERT 2026-03-28: Multiple ATM skimming devices detected at downtown branch ATMs (IDs: ATM-042, ATM-043, ATM-047). Approximately 120 customer cards potentially compromised over 48-hour window. Estimated exposure: $180,000. Pattern matches organized skimming ring reported by FBI IC3 advisory FA-2026-0315. Recommend immediate card replacement for affected customers and ATM inspection of all branches within 25-mile radius.\";"
        }
      },
      "visual" : {
        "at" : { "x" : 248, "y" : 352 }
      },
      "connect" : [
        { "id" : "f14", "to" : "f6" }
      ]
    }, {
      "id" : "f6",
      "type" : "ProgramInterface",
      "name" : "Fraud Alert Analysis Agent",
      "config" : {
        "javaClass" : "com.axonivy.utils.smart.workflow.AgenticProcessCall",
        "userConfig" : {
          "system" : "<%=ivy.cms.co(\"/Features/RagDemo/SystemPrompt\")%>",
          "tools" : "[\"searchDocuments\"]",
          "resultType" : "com.axonivy.utils.smart.workflow.rag.entity.RagResult.class",
          "resultMapping" : "in.ragResult",
          "query" : "\"Based on our fraud detection policies and the recent alert below, what immediate actions should our team take?\\nRecent Alert: \" + in.recentFraudAlert + \"\\nSearch the fraud detection policy and the alert text for relevant sections. Sources should include cms:/Features/RagDemo/FraudDetectionPolicy and the alert text.\""
        }
      },
      "visual" : {
        "at" : { "x" : 456, "y" : 353 },
        "size" : { "width" : 160, "height" : 62 }
      },
      "connect" : [
        { "id" : "f15", "to" : "f7" }
      ]
    }, {
      "id" : "f7",
      "type" : "Script",
      "name" : "Log result",
      "config" : {
        "output" : {
          "code" : [
            "import com.axonivy.utils.smart.workflow.rag.entity.RagMatch;",
            "import com.axonivy.utils.smart.workflow.rag.entity.RagResult;",
            "",
            "RagResult ragResult = in.ragResult;",
            "ivy.log.info(\"RAG answer: {0}\", ragResult.getAnswer());",
            "if (ragResult.getMatches() != null) {",
            "  int i = 1;",
            "  for (RagMatch match : ragResult.getMatches()) {",
            "    ivy.log.info(\"  Match {0} (score={1}): {2}\", i++, match.getScore(), match.getContent());",
            "  }",
            "}"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 672, "y" : 352 }
      },
      "connect" : [
        { "id" : "f16", "to" : "f8" }
      ]
    }, {
      "id" : "f8",
      "type" : "TaskEnd",
      "visual" : {
        "at" : { "x" : 840, "y" : 352 }
      }
    } ]
}