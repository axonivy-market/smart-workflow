            "name" : "yes",
            "segment" : 1.5
          } }
      ]
    }, {
      "id" : "f7",
      "type" : "Script",
      "name" : "Add user message",
      "config" : {
        "output" : {
          "code" : [
            "import java.time.LocalDateTime;",
            "import java.time.format.DateTimeFormatter;",
            "import com.axonivy.utils.smart.workflow.demo.rag.RagDemo.ChatMessage;",
            "",
            "ChatMessage msg = new ChatMessage();",
            "msg.setRole(\"user\");",
            "msg.setContent(in.userInput);",
            "msg.setTimestamp(LocalDateTime.now().format(DateTimeFormatter.ofPattern(\"h:mm a\")));",
            "in.messages.add(msg);",
            "in.question = in.userInput;",
            "in.userInput = \"\";"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 560, "y" : 296 }
      },
      "connect" : [
        { "id" : "c5", "to" : "f8" }
      ]
    }, {
      "id" : "f8",
      "type" : "ProgramInterface",
      "name" : "AI Response",
      "config" : {
        "javaClass" : "com.axonivy.utils.smart.workflow.AgenticProcessCall",
        "userConfig" : {
          "system" : "You are a helpful AI assistant. Answer questions clearly and concisely. Be friendly and informative.",
          "tools" : "[]",
          "resultMapping" : "in.answer",
          "query" : "<%=in.question%>"
        },
        "exceptionHandler" : "f15"
      },
      "visual" : {
        "at" : { "x" : 752, "y" : 296 },
        "size" : { "width" : 160, "height" : 62 }
      },
      "connect" : [
        { "id" : "c6", "to" : "f9" }
      ]
    }, {
      "id" : "f9",
      "type" : "Script",
      "name" : "Handle response",
      "config" : {
        "output" : {
          "code" : [
            "import java.time.LocalDateTime;",
            "import java.time.format.DateTimeFormatter;",
            "import com.axonivy.utils.smart.workflow.demo.rag.RagDemo.ChatMessage;",
            "",
            "ChatMessage msg = new ChatMessage();",
            "msg.setRole(\"assistant\");",
            "msg.setContent(in.answer != null && !in.answer.isBlank() ? in.answer : \"Sorry, I could not generate a response.\");",
            "msg.setTimestamp(LocalDateTime.now().format(DateTimeFormatter.ofPattern(\"h:mm a\")));",
            "in.messages.add(msg);",
            "in.answer = \"\";"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 944, "y" : 296 }
