      "id" : "f15",
      "type" : "ErrorStartEvent",
      "name" : "ivy:error:program:exception",
      "config" : {
        "errorCode" : "ivy:error:program:exception",
        "output" : {
          "code" : [
            "import java.time.LocalDateTime;",
            "import java.time.format.DateTimeFormatter;",
            "import com.axonivy.utils.smart.workflow.demo.rag.RagDemo.ChatMessage;",
            "",
            "ivy.log.error(\"AI Chat error: \" + exception);",
            "ChatMessage errMsg = new ChatMessage();",
            "errMsg.setRole(\"assistant\");",
            "errMsg.setContent(\"An error occurred: \" + exception);",
            "errMsg.setTimestamp(LocalDateTime.now().format(DateTimeFormatter.ofPattern(\"h:mm a\")));",
            "in.messages.add(errMsg);"
          ]
        }
      },
