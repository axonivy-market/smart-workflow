            "",
            "AgentProcessingStep step3 = new AgentProcessingStep();",
            "step3.setName(\"Risk Score Calculation\");",
            "steps.add(step3);",
            "",
            "response.setProcessingSteps(steps);",
            "in.agentResponse = response;"
