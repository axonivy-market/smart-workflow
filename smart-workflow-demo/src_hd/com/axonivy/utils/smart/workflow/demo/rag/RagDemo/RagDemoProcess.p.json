        { "id" : "f32", "to" : "f23" }
      ]
    }, {
      "id" : "f23",
      "type" : "Script",
      "name" : "Load documents from OpenSearch",
      "config" : {
        "output" : {
          "code" : [
            "import com.axonivy.utils.smart.workflow.rag.opensearch.internal.OpenSearchRestClient;",
            "import Features.RagDemo.IndexMetaView;",
            "import Features.RagDemo.EmbeddedChunkView;",
            "import javax.faces.application.FacesMessage;",
            "import javax.faces.context.FacesContext;",
            "import dev.langchain4j.data.segment.TextSegment;",
            "import dev.langchain4j.store.embedding.EmbeddingMatch;",
            "import dev.langchain4j.store.embedding.EmbeddingSearchResult;",
            "",
            "if (org.apache.commons.lang3.StringUtils.isBlank(in.indexName)) {",
            "  FacesContext.getCurrentInstance().addMessage(null,",
            "    new FacesMessage(FacesMessage.SEVERITY_ERROR, \"Index name is required.\", null));",
            "} else {",
            "  try {",
            "    OpenSearchRestClient client = OpenSearchRestClient.fromIvyVars();",
            "    if (!client.indexExists(in.indexName)) {",
            "      in.embeddedChunks = new java.util.ArrayList();",
            "      in.indexMeta = null;",
            "    } else {",
            "      EmbeddingSearchResult result = client.listDocuments(in.indexName, 200);",
            "      java.util.List chunks = new java.util.ArrayList();",
            "      for (EmbeddingMatch match : result.matches()) {",
            "        TextSegment segment = match.embedded() as TextSegment;",
            "        String source = segment.metadata().getString(\"source\");",
            "        String preview = segment.text();",
            "        EmbeddedChunkView chunk = new EmbeddedChunkView();",
            "        chunk.setId(match.embeddingId());",
            "        chunk.setSource(source != null ? source : \"-\");",
            "        chunk.setTextPreview(preview);",
            "        chunks.add(chunk);",
            "      }",
            "      in.embeddedChunks = chunks;",
            "      com.axonivy.utils.smart.workflow.rag.opensearch.internal.OpenSearchIndexMeta raw = client.getIndexMeta(in.indexName);",
            "      IndexMetaView meta = new IndexMetaView();",
            "      meta.setEmbeddingProvider(raw.embeddingProvider());",
            "      meta.setEmbeddingModel(raw.embeddingModel());",
            "      meta.setChunkSize(raw.chunkSize());",
            "      meta.setChunkOverlap(raw.chunkOverlap());",
            "      String rawDate = raw.createdAt();",
            "      if (rawDate != null && !rawDate.isEmpty()) {",
            "        try {",
            "          java.time.Instant instant = java.time.Instant.parse(rawDate);",
            "          rawDate = java.time.format.DateTimeFormatter.ofPattern(\"MMM dd, yyyy HH:mm\")",
            "            .withZone(java.time.ZoneOffset.UTC).format(instant);",
            "        } catch (Exception ignored) {}",
            "      }",
            "      meta.setCreatedAt(rawDate);",
            "      in.indexMeta = meta;",
            "    }",
            "  } catch (Exception ex) {",
            "    ivy.log.error(\"Load documents failed\", ex);",
            "    FacesContext.getCurrentInstance().addMessage(null,",
            "      new FacesMessage(FacesMessage.SEVERITY_ERROR, \"Could not load documents: \" + ex.getMessage(), null));",
            "  }",
            "}"
          ]
        }
      },
