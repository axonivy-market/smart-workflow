      "id" : "f26",
      "type" : "Script",
      "name" : "Process embed result",
      "config" : {
        "output" : {
          "code" : [
            "import javax.faces.application.FacesMessage;",
            "import javax.faces.context.FacesContext;",
            "",
            "FacesContext fc = FacesContext.getCurrentInstance();",
            "boolean success = in.ragResult != null && !in.ragResult.hasError();",
            "if (in.ragResult == null) {",
            "  fc.addMessage(null, new FacesMessage(FacesMessage.SEVERITY_ERROR,",
            "    \"Embed process did not return a result. Check server logs.\", null));",
            "} else if (in.ragResult.hasError()) {",
            "  fc.addMessage(null, new FacesMessage(FacesMessage.SEVERITY_ERROR,",
            "    \"Embed failed: \" + in.ragResult.getError(), null));",
            "} else {",
            "  in.stagedFiles.clear();",
            "  in.sources.clear();",
            "  in.currentStep = 3;",
            "  fc.addMessage(null, new FacesMessage(FacesMessage.SEVERITY_INFO,",
            "    in.ragResult.getAnswer(), null));",
            "}",
            "org.primefaces.PrimeFaces.current().ajax().addCallbackParam(\"embedSuccess\", success);"
          ]
        }
      },
