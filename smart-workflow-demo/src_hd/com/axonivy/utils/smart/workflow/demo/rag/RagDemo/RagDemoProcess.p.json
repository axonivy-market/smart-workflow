      "name" : "Stage uploaded file",
      "config" : {
        "output" : {
          "code" : [
            "import Features.RagDemo.UploadedFile;",
            "",
            "String fileName = in.uploadEvent.getFile().getFileName();",
            "",
            "UploadedFile uploaded = new UploadedFile();",
            "uploaded.setName(fileName);",
            "",
            "if (fileName.toLowerCase().endsWith(\".pdf\")) {",
            "  uploaded.setBinary(new ch.ivyteam.ivy.scripting.objects.Binary(in.uploadEvent.getFile().getContent()));",
            "  uploaded.setSizeKb(in.uploadEvent.getFile().getSize() / 1024);",
            "  in.stagedFiles.add(uploaded);",
            "} else {",
            "  String content = new String(in.uploadEvent.getFile().getContent(), java.nio.charset.StandardCharsets.UTF_8);",
            "  uploaded.setContent(content);",
            "  uploaded.setSizeKb(content.length() / 1024);",
            "  in.stagedFiles.add(uploaded);",
            "  in.sources.add(content);",
            "}"
          ]
        }
