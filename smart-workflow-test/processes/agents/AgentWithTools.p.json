{
  "$schema" : "https://json-schema.axonivy.com/14.0-dev/project/process.json",
  "id" : "19D000D24BEB2CAF",
  "config" : {
    "data" : "agents.AgentWithToolsData"
  },
  "elements" : [ {
      "id" : "f0",
      "type" : "RequestStart",
      "name" : "callAgentDemo",
      "config" : {
        "signature" : "callAgentDemo",
        "request" : {
          "name" : "Agent With Tools Demo"
        }
      },
      "visual" : {
        "at" : { "x" : 96, "y" : 64 }
      },
      "connect" : [
        { "id" : "f20", "to" : "f18" }
      ]
    }, {
      "id" : "f1",
      "type" : "TaskEnd",
      "visual" : {
        "at" : { "x" : 1320, "y" : 64 }
      }
    }, {
      "id" : "f2",
      "type" : "Script",
      "name" : "Load Invoice PNG as InputStream",
      "config" : {
        "output" : {
          "code" : [
            "import com.axonivy.utils.smart.workflow.demo.utils.FileProcessingUtils;",
            "",
            "in.invoiceStream = FileProcessingUtils.loadInputStreamFromCms(\"/Features/FileExtractionDemo/InvoiceImage\");"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 328, "y" : 64 }
      },
      "connect" : [
        { "id" : "f22", "to" : "f3" }
      ]
    }, {
      "id" : "f18",
      "type" : "TaskSwitchEvent",
      "name" : "Process Invoice",
      "config" : {
        "task" : {
          "name" : "Process Invoice",
          "skipTasklist" : true
        },
        "case" : {
          "name" : "Invoice Analysis"
        }
      },
      "visual" : {
        "at" : { "x" : 200, "y" : 64 }
      },
      "connect" : [
        { "id" : "f21", "to" : "f2" }
      ]
    }, {
      "id" : "f3",
      "type" : "ProgramInterface",
      "name" : "Extract Invoice Content from Image",
      "config" : {
        "javaClass" : "com.axonivy.utils.smart.workflow.AgenticProcessCall",
        "userConfig" : {
          "system" : "You are an invoice OCR specialist. Extract all text content from the invoice image exactly as it appears, preserving structure, labels, values, and layout as clearly as possible.",
          "tools" : "[]",
          "resultMapping" : "in.invoiceContent",
          "query" : "Extract all text content from this invoice image: <%=in.invoiceStream%>"
        }
      },
      "visual" : {
        "at" : { "x" : 512, "y" : 64 },
        "size" : { "width" : 152, "height" : 62 }
      },
      "connect" : [
        { "id" : "f23", "to" : "f4" }
      ]
    }, {
      "id" : "f4",
      "type" : "SubProcessCall",
      "name" : "Analyze Invoice",
      "config" : {
        "processCall" : "agents/callable/InvoiceAnalyzer:call(String)",
        "call" : {
          "map" : {
            "param.invoiceContent" : "in.invoiceContent"
          }
        },
        "output" : {
          "map" : {
            "out.analysisResult" : "result.analysisResult"
          }
        }
      },
      "visual" : {
        "at" : { "x" : 744, "y" : 64 },
        "size" : { "width" : 152, "height" : 62 }
      },
      "connect" : [
        { "id" : "f9", "to" : "f5", "color" : "default" }
      ]
    }, {
      "id" : "f5",
      "type" : "Script",
      "name" : "Log Analysis Result",
      "config" : {
        "output" : {
          "code" : [
            "ivy.log.warn(\"=== Invoice Analysis Result ===\");",
            "ivy.log.warn(\"{0}\", in.analysisResult);"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 968, "y" : 64 }
      },
      "connect" : [
        { "id" : "f10", "to" : "f11", "color" : "default" }
      ]
    }, {
      "id" : "f11",
      "type" : "Script",
      "name" : "Log Agent History as JSON",
      "config" : {
        "output" : {
          "code" : [
            "import com.axonivy.utils.smart.workflow.governance.history.internal.AgentHistoryTreeBuilder;",
            "import com.axonivy.utils.smart.workflow.governance.history.storage.internal.IvyRepoHistoryStorage;",
            "import com.axonivy.utils.smart.workflow.utils.JsonUtils;",
            "",
            "String caseUuid = ivy.case.uuid();",
            "in.result = AgentHistoryTreeBuilder.buildTree(",
            "    new IvyRepoHistoryStorage().findByCaseUuid(caseUuid));",
            "",
            "ivy.log.warn(\"=== Agent History Tree (JSON) ===\");",
            "ivy.log.warn(JsonUtils.getObjectMapper().writeValueAsString(in.result));"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 1128, "y" : 64 }
      },
      "connect" : [
        { "id" : "f12", "to" : "f1", "color" : "default" }
      ]
    } ]
}