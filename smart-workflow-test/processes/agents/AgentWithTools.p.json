{
  "$schema" : "https://json-schema.axonivy.com/14.0-dev/project/process.json",
  "id" : "19D000D24BEB2CAF",
  "config" : {
    "data" : "agents.AgentWithToolsData"
  },
  "elements" : [ {
      "id" : "f0",
      "type" : "RequestStart",
      "name" : "callAgentDemo",
      "config" : {
        "signature" : "callAgentDemo",
        "request" : {
          "name" : "Agent With Tools Demo"
        }
      },
      "visual" : {
        "at" : { "x" : 96, "y" : 64 }
      },
      "connect" : [
        { "id" : "f6", "to" : "f2" }
      ]
    }, {
      "id" : "f1",
      "type" : "TaskEnd",
      "visual" : {
        "at" : { "x" : 1024, "y" : 64 }
      }
    }, {
      "id" : "f2",
      "type" : "Script",
      "name" : "Load Invoice PNG as InputStream",
      "config" : {
        "output" : {
          "code" : [
            "import com.axonivy.utils.smart.workflow.demo.utils.FileProcessingUtils;",
            "",
            "in.invoiceStream = FileProcessingUtils.loadInputStreamFromCms(\"/Features/FileExtractionDemo/InvoiceImage\");"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 224, "y" : 64 }
      },
      "connect" : [
        { "id" : "f7", "to" : "f3", "color" : "default" }
      ]
    }, {
      "id" : "f3",
      "type" : "ProgramInterface",
      "name" : "Extract Invoice Content from Image",
      "config" : {
        "javaClass" : "com.axonivy.utils.smart.workflow.AgenticProcessCall",
        "userConfig" : {
          "system" : "You are an invoice OCR specialist. Extract all text content from the invoice image exactly as it appears, preserving structure, labels, values, and layout as clearly as possible.",
          "tools" : "[]",
          "resultMapping" : "in.invoiceContent",
          "query" : "Extract all text content from this invoice image: <%=in.invoiceStream%>"
        }
      },
      "visual" : {
        "at" : { "x" : 408, "y" : 64 },
        "size" : { "width" : 152, "height" : 62 }
      },
      "connect" : [
        { "id" : "f8", "to" : "f4", "color" : "default" }
      ]
    }, {
      "id" : "f4",
      "type" : "SubProcessCall",
      "name" : "Analyze Invoice",
      "config" : {
        "processCall" : "agents/callable/InvoiceAnalyzer:call(String)",
        "call" : {
          "map" : {
            "param.invoiceContent" : "in.invoiceContent"
          }
        },
        "output" : {
          "map" : {
            "out.analysisResult" : "result.analysisResult"
          }
        }
      },
      "visual" : {
        "at" : { "x" : 640, "y" : 64 },
        "size" : { "width" : 152, "height" : 62 }
      },
      "connect" : [
        { "id" : "f9", "to" : "f5", "color" : "default" }
      ]
    }, {
      "id" : "f5",
      "type" : "Script",
      "name" : "Log Analysis Result",
      "config" : {
        "output" : {
          "code" : [
            "ivy.log.warn(\"=== Invoice Analysis Result ===\");",
            "ivy.log.warn(\"{0}\", in.analysisResult);"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 864, "y" : 64 }
      },
      "connect" : [
        { "id" : "f10", "to" : "f1", "color" : "default" }
      ]
    } ]
}
