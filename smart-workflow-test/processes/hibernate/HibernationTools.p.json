        "signature" : "askUserYesOrNo",
        "input" : {
          "params" : [
            { "name" : "question", "type" : "String", "desc" : "the decision to be made" }
          ],
          "map" : {
            "out.decision.question" : "param.question"
          },
          "code" : [
            "import hibernate.Choice;",
            "",
            "Choice yes = new Choice();",
            "yes.title = \"yes\";",
            "Choice no = new Choice();",
            "no.title = \"no\";",
            "",
            "out.decision.options=[yes, no];",
            "",
            "ivy.log.info(\"LLM asks: \" + param.question);"
          ]
        },
        "result" : {
          "params" : [
            { "name" : "accepted", "type" : "Boolean", "desc" : "users choice" }
          ],
          "map" : {
            "result.accepted" : "in.selected.get(0).title.equals(\"yes\")"
          }
        }
      },
