{
  "$schema" : "https://json-schema.axonivy.com/14.0-dev/project/process.json",
  "id" : "19898DB41125BF26",
  "kind" : "CALLABLE_SUB",
  "config" : {
    "data" : "tools.aiServantData"
  },
  "elements" : [ {
      "id" : "f0",
      "type" : "CallSubStart",
      "name" : "whoami()",
      "config" : {
        "signature" : "whoami",
        "result" : {
          "params" : [
            { "name" : "person", "type" : "com.axonivy.utils.smart.workflow.test.Person", "desc" : "the current user" }
          ],
          "map" : {
            "result.person.firstName" : "ivy.session.getSessionUserName()"
          }
        }
      },
      "tags" : [
        "tool"
      ],
      "visual" : {
        "at" : { "x" : 96, "y" : 64 },
        "description" : "provides information about the current user"
      },
      "connect" : [
        { "id" : "f2", "to" : "f1" }
      ]
    }, {
      "id" : "f1",
      "type" : "CallSubEnd",
      "visual" : {
        "at" : { "x" : 352, "y" : 64 }
      }
    }, {
      "id" : "f3",
      "type" : "CallSubStart",
      "name" : "add(Integer,Integer)",
      "config" : {
        "signature" : "add",
        "input" : {
          "params" : [
            { "name" : "a", "type" : "Integer", "desc" : "first number" },
            { "name" : "b", "type" : "Integer", "desc" : "number to be added" }
          ],
          "map" : {
            "out.result" : "param.a.intValue() + param.b.intValue()"
          }
        },
        "result" : {
          "params" : [
            { "name" : "c", "type" : "Integer", "desc" : "the calculated result" }
          ],
          "map" : {
            "result.c" : "in.result"
          }
        }
      },
      "tags" : [
        "tool"
      ],
      "visual" : {
        "at" : { "x" : 96, "y" : 200 },
        "description" : "This is a simple calculator: supporting additions of numbers"
      },
      "connect" : [
        { "id" : "f5", "to" : "f4" }
      ]
    }, {
      "id" : "f4",
      "type" : "CallSubEnd",
      "visual" : {
        "at" : { "x" : 352, "y" : 200 }
      }
    }, {
      "id" : "f6",
      "type" : "CallSubStart",
      "name" : "disconnected(String)",
      "config" : {
        "signature" : "disconnected",
        "input" : {
          "params" : [
            { "name" : "user", "type" : "String", "desc" : "user to test availability" }
          ],
          "map" : { }
        },
        "result" : {
          "params" : [
            { "name" : "available", "type" : "Boolean", "desc" : "" }
          ],
          "map" : {
            "result.available" : "false"
          }
        }
      },
      "tags" : [
        "tool"
      ],
      "visual" : {
        "at" : { "x" : 96, "y" : 320 },
        "description" : "Call me to verify the availability of a chat user"
      },
      "connect" : [
        { "id" : "f8", "to" : "f7" }
      ]
    }, {
      "id" : "f7",
      "type" : "ErrorEnd",
      "name" : "connection:problem",
      "config" : {
        "throws" : {
          "error" : "connection:problem"
        }
      },
      "visual" : {
        "at" : { "x" : 352, "y" : 320 }
      }
    } ]
}